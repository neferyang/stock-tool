# ════════════════════════════════════════════
# GitHub Pages 白名單配置
# 只推送核心生產文件，所有其他文件被忽略
# ════════════════════════════════════════════

# 忽略所有檔案
*

# ════════════════════════════════════════════
# 核心應用文件
# ════════════════════════════════════════════
!index.html                    # 主應用（股票估價工具）
!index_v6_ai.html              # 財金早報分頁

# ════════════════════════════════════════════
# 配置文件
# ════════════════════════════════════════════
!.gitignore                    # Git 配置
!README.md                     # 項目文檔
!vercel.json                   # Vercel 配置

# ════════════════════════════════════════════
# API 和後端
# ════════════════════════════════════════════
!api/                          # Vercel 函數目錄
!api/proxy.js                  # 後端代理
!api/stocks.js                 # 台股數據 API（Vercel Serverless）
!api/stock/                    # 動態路由目錄
!api/stock/[code].js           # 單支股票 API（動態路由）

# ════════════════════════════════════════════
# 自動化和數據
# ════════════════════════════════════════════
!update-daily-report.js        # 每日更新腳本
!update-international-markets.js  # 國際市場更新
!daily-report.json             # 每日報告數據
!fetch-stock-data.py           # yfinance 數據抓取腳本（完整版）
!fetch-stock-data-lite.py      # yfinance 數據抓取腳本（簡化版）
!tw-stocks.json                # 台股數據（本地快照）
!us-stocks.json                # 美股數據（本地快照）
!test-stocks.json              # 測試數據
!backend.py                    # Flask 後端服務（FinMind API 代理）

# ════════════════════════════════════════════
# GitHub Actions 工作流
# ════════════════════════════════════════════
!.github/                      # GitHub 配置目錄
!.github/workflows/            # 工作流目錄
!.github/workflows/daily-report-update.yml  # 每日更新工作流

# ════════════════════════════════════════════
# 文檔目錄
# ════════════════════════════════════════════
!docs/                         # 開發文檔目錄
!docs/*.md                     # 所有文檔檔案
